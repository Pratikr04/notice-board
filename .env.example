# Prisma Postgres connection string.
# Get this for free (no credit card) at https://console.prisma.io  -> create a Postgres database.
# It looks like: prisma+postgres://accelerate.prisma-data.net/?api_key=...
# A standard Postgres URL from Neon/Supabase also works (postgresql://USER:PASS@HOST/DB?sslmode=require).
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"
